{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5433;Database=adswe_events;Username=adswe;Password=adswe",
    "Redis": "localhost:6379"
  },
  "Cors": {
    "AllowAllOrigins": true,
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  },
  "AquariumRegistry": {
    "BaseUrl": "http://localhost:7214",
    "FreshWaterPath": "/api/FreshWaterAquarium",
    "SeaWaterPath": "/api/SeaWaterAquarium",
    "ServiceAuth": {
      "HeaderName": "X-Service-Key",
      "ApiKey": "ChangeThisServiceApiKey!"
    }
  },
  "GraphQl": {
    "Endpoint": "http://localhost:7216/graphql"
  },
  "Outbox": {
    "BatchSize": 100,
    "PollIntervalSeconds": 5
  },
  "Feeding": {
    "DefaultIntervalMinutes": 2
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
